{
  "entities": {
    "WaitlistEntry": {
      "title": "Waitlist Entry",
      "description": "Information about a user who joined the LancerFlow waitlist.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email address of the user."
        },
        "name": {
          "type": "string",
          "description": "The name of the user (optional)."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user joined the waitlist."
        }
      },
      "required": ["email", "createdAt"]
    }
  },
  "firestore": {
    "/waitlist/{entryId}": {
      "schema": "WaitlistEntry",
      "description": "Collection of waitlist signups."
    }
  }
}
